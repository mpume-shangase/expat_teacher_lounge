# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Site URL (must match your Vercel / custom domain exactly) ─────────────────
# Used as the OAuth redirect base. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://expat-teacher-lounge.vercel.app

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_...
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Hostinger Reach ───────────────────────────────────────────────────────────
# API key: Hostinger Reach dashboard → Settings → API
HOSTINGER_REACH_API_KEY=your_reach_api_key

# Audience list ID: Reach dashboard → Lists → click your list → copy the ID from the URL
HOSTINGER_REACH_LIST_ID=your_list_id

# Transactional template IDs (Reach dashboard → Templates → click template → copy ID)
# Leave blank to skip that email type
HOSTINGER_REACH_WELCOME_TEMPLATE_ID=
HOSTINGER_REACH_SUBSCRIPTION_TEMPLATE_ID=
