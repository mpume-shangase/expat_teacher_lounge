{%- comment -%}
  Renders a product card item for catalog pages
  Accepts:
  - product: {Object} Product object
  - is_coaching: {Boolean} Whether the product is coaching
{%- endcomment -%}

{%- assign is_coaching = is_coaching | default: false -%}
{%- assign card_link = product.url -%}


<a href="{{ card_link }}" class="product-toolkit-card group" style="display: flex; flex-direction: column; background-color: #fafafc; border: 1px solid #e5e7eb; border-radius: var(--border-radius-lg); padding: 40px; transition: var(--transition-smooth); height: 100%;">
  
  {%- if product.featured_image != blank -%}
    <!-- Cover Image Container with Contain and Padding -->
    <div class="product-toolkit-image-wrapper" style="position: relative; width: 100%; aspect-ratio: 4/3; border-radius: var(--border-radius-md); overflow: hidden; margin-bottom: 32px; border: 1px solid #e5e7eb; background-color: rgba(243, 244, 246, 0.5); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
      <img src="{{ product.featured_image | image_url: width: 800 }}" 
           alt="{{ product.title | escape }}" 
           style="width: 100%; height: 100%; object-fit: contain; padding: 24px; transition: var(--transition-smooth);"
           class="product-toolkit-img"
           loading="lazy">
    </div>
  {%- else -%}
    <!-- Small File Icon Fallback (matches Next.js w-16 h-16 circular icon) -->
    <div class="product-toolkit-fallback-icon" style="width: 64px; height: 64px; background-color: rgba(28, 145, 215, 0.08); display: flex; align-items: center; justify-content: center; border-radius: 50%; color: var(--color-blue); margin-bottom: 32px; flex-shrink: 0; transition: var(--transition-smooth);">
      <svg style="width: 32px; height: 32px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        {%- if is_coaching -%}
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        {%- else -%}
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        {%- endif -%}
      </svg>
    </div>
  {%- endif -%}

  <!-- Product Title -->
  <h3 class="font-display font-bold product-toolkit-title" style="font-size: 1.875rem; line-height: 1.3; color: var(--text-light); margin-top: 0; margin-bottom: 24px; transition: var(--transition-smooth); flex-grow: 1;">
    {{ product.title }}
  </h3>

  <!-- Card Bottom (Border top, price, buy button) -->
  <div class="flex items-center justify-between" style="border-top: 1px solid #e5e7eb; padding-top: 32px; margin-top: auto; width: 100%;">
    <span style="font-size: 1.5rem; font-weight: 700; color: var(--text-light);">
      {{ product.price | money }}
    </span>
    <span class="product-toolkit-btn" style="background-color: var(--color-blue, #1C91D7); color: #ffffff; padding: 12px 24px; border-radius: var(--border-radius-full); font-weight: 700; transition: var(--transition-smooth);">
      {% if is_coaching %}Book Session{% else %}Purchase Now{% endif %}
    </span>
  </div>

</a>
