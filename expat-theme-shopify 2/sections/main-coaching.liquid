{%- assign pkg1_product = nil -%}
{%- assign pkg1_variant = nil -%}
{%- if section.settings.pkg1_product != blank -%}
  {%- if section.settings.pkg1_product.title != blank -%}
    {%- assign pkg1_product = section.settings.pkg1_product -%}
  {%- else -%}
    {%- assign pkg1_product = all_products[section.settings.pkg1_product] -%}
  {%- endif -%}
  {%- if pkg1_product != blank -%}
    {%- assign pkg1_variant = pkg1_product.first_available_variant | default: pkg1_product.variants.first -%}
  {%- endif -%}
{%- endif -%}

{%- assign pkg2_product = nil -%}
{%- assign pkg2_variant = nil -%}
{%- if section.settings.pkg2_product != blank -%}
  {%- if section.settings.pkg2_product.title != blank -%}
    {%- assign pkg2_product = section.settings.pkg2_product -%}
  {%- else -%}
    {%- assign pkg2_product = all_products[section.settings.pkg2_product] -%}
  {%- endif -%}
  {%- if pkg2_product != blank -%}
    {%- assign pkg2_variant = pkg2_product.first_available_variant | default: pkg2_product.variants.first -%}
  {%- endif -%}
{%- endif -%}

<!-- Coaching Page Section -->
<section id="coaching-section-{{ section.id }}" class="coaching-page-wrapper">
  
  <style>
    .coaching-page-wrapper {
      width: 100%;
      background-color: var(--bg-light, #ffffff);
      color: var(--text-light, #0a0a14);
      font-family: var(--font-body), sans-serif;
    }
    
    /* --- COMMON STYLES --- */
    .coaching-section-padding {
      padding: 80px 24px;
    }
    @media (min-width: 992px) {
      .coaching-section-padding {
        padding: 120px 24px;
      }
    }
    
    .coaching-container {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
    }
    
    /* --- SECTION 1: HERO --- */
    .coaching-hero {
      position: relative;
      height: 70vh;
      min-height: 520px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #0a0b14;
      text-align: center;
      overflow: hidden;
    }
    
    .coaching-hero__bg {
      position: absolute;
      inset: 0;
      z-index: 1;
    }
    .coaching-hero__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      opacity: 0.25;
    }
    .coaching-hero__overlay-dark {
      position: absolute;
      inset: 0;
      background-color: rgba(10, 11, 20, 0.75);
      z-index: 2;
    }
    .coaching-hero__overlay-fade {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, var(--bg-light, #ffffff) 0%, rgba(10, 11, 20, 0) 100%);
      z-index: 3;
    }
    
    .coaching-hero__content {
      position: relative;
      z-index: 10;
      color: #ffffff;
      margin-top: 80px;
      padding: 0 24px;
    }
    
    .coaching-hero__title {
      font-family: var(--font-display), serif;
      font-weight: 900;
      font-size: clamp(2.5rem, 7vw, 4.5rem);
      line-height: 1.1;
      margin-bottom: 24px;
      color: #ffffff !important;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
    }
    
    .coaching-hero__title span {
      color: var(--color-brand-gold, #FCCB52);
      font-style: italic;
    }
    
    .coaching-hero__description {
      font-size: clamp(1.1rem, 2.5vw, 1.45rem);
      color: rgba(255, 255, 255, 0.85) !important;
      max-width: 650px;
      margin: 0 auto 40px auto;
      line-height: 1.5;
      text-shadow: 0 1px 5px rgba(0, 0, 0, 0.3);
    }
    
    .coaching-hero__btn {
      display: inline-block;
      background-color: var(--color-blue, #1C91D7);
      color: #ffffff !important;
      padding: 16px 36px;
      font-weight: 700;
      border-radius: 9999px;
      box-shadow: 0 10px 20px rgba(28, 145, 215, 0.25);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .coaching-hero__btn:hover {
      background-color: var(--color-deep, #143D8A);
      transform: translateY(-2px);
      box-shadow: 0 15px 25px rgba(28, 145, 215, 0.35);
    }
    
    /* --- SECTION 2: PACKAGES --- */
    .coaching-packages {
      background-color: var(--bg-light, #ffffff);
    }
    
    .coaching-packages__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
      max-width: 1000px;
      margin: 0 auto;
    }
    @media (min-width: 768px) {
      .coaching-packages__grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    /* Package 1: Light Card */
    .coaching-card-light {
      background-color: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      padding: 40px;
      display: flex;
      flex-direction: column;
      height: 100%;
      position: relative;
      overflow: hidden;
      box-shadow: 0 4px 6px rgba(0,0,0,0.02);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .coaching-card-light:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
    }
    .coaching-card-light__glow {
      position: absolute;
      top: 0;
      right: 0;
      width: 128px;
      height: 128px;
      background-color: rgba(28, 145, 215, 0.08);
      border-radius: 50%;
      filter: blur(30px);
      pointer-events: none;
    }
    
    .coaching-card__title {
      font-family: var(--font-display), serif;
      font-weight: 900;
      font-size: clamp(1.5rem, 3vw, 1.85rem);
      line-height: 1.2;
      margin-bottom: 8px;
      color: var(--text-light, #0a0a14);
    }
    
    .coaching-card__meta {
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: #64748b;
      margin-bottom: 24px;
    }
    
    .coaching-card__price {
      font-size: 3rem;
      font-weight: 900;
      color: var(--color-blue, #1C91D7);
      margin-bottom: 32px;
      line-height: 1;
    }
    
    .coaching-card__list {
      list-style: none;
      padding: 0;
      margin: 0 0 40px 0;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    
    .coaching-card__item {
      display: flex;
      align-items: start;
      line-height: 1.5;
      color: #334155;
      font-size: 0.95rem;
    }
    
    .coaching-card__item-icon {
      width: 22px;
      height: 22px;
      color: var(--color-brand-gold, #FCCB52);
      margin-right: 12px;
      flex-shrink: 0;
    }
    
    .coaching-card-light__btn {
      display: block;
      width: 100%;
      text-align: center;
      background-color: #0f172a;
      color: #ffffff !important;
      padding: 16px 24px;
      border-radius: 9999px;
      font-weight: 700;
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px rgba(15, 23, 42, 0.15);
    }
    .coaching-card-light__btn:hover {
      background-color: var(--color-blue, #1C91D7);
      transform: scale(1.02);
      box-shadow: 0 10px 20px rgba(28, 145, 215, 0.25);
    }
    
    /* Package 2: Dark Blue Card */
    .coaching-card-dark {
      background-color: var(--color-brand-deep, #143D8A);
      border: 1px solid var(--color-brand-deep, #143D8A);
      border-radius: 24px;
      padding: 40px;
      display: flex;
      flex-direction: column;
      height: 100%;
      position: relative;
      overflow: hidden;
      color: #ffffff;
      box-shadow: 0 10px 25px rgba(20, 61, 138, 0.25);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .coaching-card-dark:hover {
      transform: translateY(-6px);
      box-shadow: 0 25px 50px rgba(20, 61, 138, 0.35);
    }
    .coaching-card-dark__glow {
      position: absolute;
      top: 0;
      right: 0;
      width: 128px;
      height: 128px;
      background-color: rgba(252, 203, 82, 0.18);
      border-radius: 50%;
      filter: blur(35px);
      pointer-events: none;
    }
    
    .coaching-card-dark .coaching-card__title {
      color: #ffffff;
    }
    
    .coaching-card-dark .coaching-card__meta {
      color: #93c5fd;
    }
    
    .coaching-card-dark .coaching-card__price {
      color: var(--color-brand-gold, #FCCB52);
    }
    
    .coaching-card-dark .coaching-card__item {
      color: #f1f5f9;
    }
    
    .coaching-card-dark__btn {
      display: block;
      width: 100%;
      text-align: center;
      background-color: var(--color-brand-gold, #FCCB52);
      color: var(--color-brand-deep, #143D8A) !important;
      padding: 16px 24px;
      border-radius: 9999px;
      font-weight: 800;
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px rgba(252, 203, 82, 0.15);
    }
    .coaching-card-dark__btn:hover {
      background-color: #f7bd31;
      transform: scale(1.02);
      box-shadow: 0 10px 20px rgba(252, 203, 82, 0.3);
    }
    
    /* --- SECTION 3: BOOKING --- */
    .coaching-booking {
      background-color: #f8fafc;
      border-top: 1px solid rgba(0,0,0,0.03);
      border-bottom: 1px solid rgba(0,0,0,0.03);
      text-align: center;
    }
    
    .coaching-booking__title {
      font-family: var(--font-display), serif;
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 2.75rem);
      margin-bottom: 16px;
      color: var(--text-light, #0a0a14);
    }
    .coaching-booking__title span {
      color: var(--color-blue, #1C91D7);
      font-style: italic;
    }
    
    .coaching-booking__subtitle {
      font-size: 1.1rem;
      color: #64748b;
      margin-bottom: 48px;
    }
    
    .coaching-booking__widget {
      background-color: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.04);
      overflow: hidden;
      max-width: 900px;
      margin: 0 auto;
      position: relative;
      width: 100%;
    }
    
    .coaching-booking__video-container {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background-color: #000000;
    }
    
    .coaching-booking__placeholder {
      padding: 40px;
      color: #94a3b8;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .coaching-booking__placeholder-icon {
      width: 64px;
      height: 64px;
      color: #cbd5e1;
      margin-bottom: 16px;
    }
    .coaching-booking__placeholder-title {
      font-weight: 700;
      font-size: 1.25rem;
      color: #64748b;
      margin-bottom: 8px;
    }
    .coaching-booking__placeholder-text {
      font-size: 0.95rem;
    }
    
    /* --- SECTION 4: FAQs --- */
    .coaching-faq {
      background-color: var(--bg-light, #ffffff);
    }
    
    .coaching-faq__title {
      font-family: var(--font-display), serif;
      font-weight: 900;
      font-size: clamp(2rem, 5vw, 2.75rem);
      margin-bottom: 48px;
      text-align: center;
      color: var(--text-light, #0a0a14);
    }
    .coaching-faq__title span {
      color: var(--color-brand-gold, #FCCB52);
      font-style: italic;
    }
    
    .coaching-faq__container {
      max-width: 768px;
      margin: 0 auto;
      border-top: 1px solid #e2e8f0;
    }
    
    .coaching-faq__item {
      border-bottom: 1px solid #e2e8f0;
      padding: 24px 0;
    }
    
    .coaching-faq__button {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      text-align: left;
      font-family: var(--font-display), serif;
      font-weight: 700;
      font-size: 1.15rem;
      color: var(--text-light, #0a0a14);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
    }
    
    .coaching-faq__icon {
      color: var(--color-blue, #1C91D7);
      transition: transform 0.3s ease;
      font-size: 0.8rem;
    }
    
    .coaching-faq__answer {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: all 0.3s ease-in-out;
      padding-top: 0;
    }
    .coaching-faq__answer p {
      font-size: 0.95rem;
      line-height: 1.7;
      color: #475569;
    }
    
    /* Opened states */
    .coaching-faq__item--open .coaching-faq__icon {
      transform: rotate(180deg);
    }
    .coaching-faq__item--open .coaching-faq__answer {
      max-height: 200px;
      opacity: 1;
      padding-top: 16px;
    }
  </style>

  <!-- SECTION 1 — HERO -->
  <div class="coaching-hero">
    <div class="coaching-hero__bg">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" alt="Edwina Presentation Background">
      {%- else -%}
        <img src="{{ 'Edwina_delivering_a_presentation.png' | asset_url }}" alt="Edwina Presentation Background">
      {%- endif -%}
    </div>
    <div class="coaching-hero__overlay-dark"></div>
    <div class="coaching-hero__overlay-fade"></div>
    <div class="coaching-hero__content">
      <h1 class="coaching-hero__title">
        {{ section.settings.hero_title_prefix }} <span>{{ section.settings.hero_title_accent }}</span>
      </h1>
      <p class="coaching-hero__description">
        {{ section.settings.hero_description }}
      </p>
      <a href="#sessions" class="coaching-hero__btn">{{ section.settings.hero_button_text }}</a>
    </div>
  </div>

  <!-- SECTION 2 — PACKAGES -->
  <div id="sessions" class="coaching-section-padding coaching-packages">
    <div class="coaching-container">
      <div class="coaching-packages__grid">
        
        <!-- Package 1: Strategy -->
        <div class="coaching-card-light">
          <div class="coaching-card-light__glow"></div>
          <h3 class="coaching-card__title">{{ section.settings.pkg1_title }}</h3>
          <p class="coaching-card__meta">{{ section.settings.pkg1_meta }}</p>
          <div class="coaching-card__price">{{ section.settings.pkg1_price }}</div>
          
          <ul class="coaching-card__list">
            {%- if section.settings.pkg1_feat1 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg1_feat1 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg1_feat2 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg1_feat2 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg1_feat3 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg1_feat3 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg1_feat4 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg1_feat4 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg1_feat5 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg1_feat5 }}</span>
              </li>
            {%- endif -%}
          </ul>
          
          {%- if pkg1_variant -%}
            <a href="/cart/add?id={{ pkg1_variant.id }}&quantity=1&return_to=/checkout" class="coaching-card-light__btn">{{ section.settings.pkg_button_text }}</a>
          {%- else -%}
            <a href="#booking" class="coaching-card-light__btn">{{ section.settings.pkg_button_text }}</a>
          {%- endif -%}
        </div>
        
        <!-- Package 2: Contract Review -->
        <div class="coaching-card-dark">
          <div class="coaching-card-dark__glow"></div>
          <h3 class="coaching-card__title">{{ section.settings.pkg2_title }}</h3>
          <p class="coaching-card__meta">{{ section.settings.pkg2_meta }}</p>
          <div class="coaching-card__price">{{ section.settings.pkg2_price }}</div>
          
          <ul class="coaching-card__list">
            {%- if section.settings.pkg2_feat1 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg2_feat1 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg2_feat2 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg2_feat2 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg2_feat3 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg2_feat3 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg2_feat4 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg2_feat4 }}</span>
              </li>
            {%- endif -%}
            {%- if section.settings.pkg2_feat5 != blank -%}
              <li class="coaching-card__item">
                <svg class="coaching-card__item-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{{ section.settings.pkg2_feat5 }}</span>
              </li>
            {%- endif -%}
          </ul>
          
          {%- if pkg2_variant -%}
            <a href="/cart/add?id={{ pkg2_variant.id }}&quantity=1&return_to=/checkout" class="coaching-card-dark__btn">{{ section.settings.pkg_button_text }}</a>
          {%- else -%}
            <a href="#booking" class="coaching-card-dark__btn">{{ section.settings.pkg_button_text }}</a>
          {%- endif -%}
        </div>
        
      </div>
    </div>
  </div>

  <!-- SECTION 3 — BOOKING & DELIVERY VIDEO -->
  <div id="booking" class="coaching-section-padding coaching-booking">
    <div class="coaching-container">
      <h2 class="coaching-booking__title">
        {{ section.settings.booking_title_prefix }} <span>{{ section.settings.booking_title_accent }}</span>
      </h2>
      <p class="coaching-booking__subtitle">
        {{ section.settings.booking_subtitle }}
      </p>
      
      <div class="coaching-booking__widget">
        {%- if section.settings.video != blank -%}
          <div class="coaching-booking__video-container">
            {{ section.settings.video | video_tag: autoplay: false, loop: false, muted: false, controls: true, style: 'width: 100%; height: 100%; object-fit: cover; display: block;' }}
          </div>
        {%- elsif section.settings.video_url != blank -%}
          <div class="coaching-booking__video-container">
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=0" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=0" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
            {%- endif -%}
          </div>
        {%- elsif section.settings.video_custom_embed != blank -%}
          <div class="coaching-booking__video-container">
            {{ section.settings.video_custom_embed }}
          </div>
        {%- else -%}
          <!-- Default Video Placeholder Box -->
          <div class="coaching-booking__placeholder" style="padding: 80px 40px; min-height: 450px; justify-content: center;">
            <svg class="coaching-booking__placeholder-icon" style="width: 64px; height: 64px; color: #cbd5e1; margin-bottom: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="coaching-booking__placeholder-title">Instructional Video</p>
            <p class="coaching-booking__placeholder-text">Please upload a video or insert a YouTube/Vimeo URL in the Theme Editor settings to show how clients will receive their PDF and book their session.</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- SECTION 4 — FAQ ACCORDION -->
  <div class="coaching-section-padding coaching-faq">
    <div class="coaching-container">
      <h2 class="coaching-faq__title">
        {{ section.settings.faq_title_prefix }} <span>{{ section.settings.faq_title_accent }}</span>
      </h2>
      
      <div class="coaching-faq__container">
        
        <!-- FAQ 1 -->
        <div class="coaching-faq__item">
          <button class="coaching-faq__button" onclick="toggleFaq(this)">
            <span>{{ section.settings.faq1_q }}</span>
            <span class="coaching-faq__icon">▼</span>
          </button>
          <div class="coaching-faq__answer">
            <p>{{ section.settings.faq1_a }}</p>
          </div>
        </div>
        
        <!-- FAQ 2 -->
        <div class="coaching-faq__item">
          <button class="coaching-faq__button" onclick="toggleFaq(this)">
            <span>{{ section.settings.faq2_q }}</span>
            <span class="coaching-faq__icon">▼</span>
          </button>
          <div class="coaching-faq__answer">
            <p>{{ section.settings.faq2_a }}</p>
          </div>
        </div>
        
        <!-- FAQ 3 -->
        <div class="coaching-faq__item">
          <button class="coaching-faq__button" onclick="toggleFaq(this)">
            <span>{{ section.settings.faq3_q }}</span>
            <span class="coaching-faq__icon">▼</span>
          </button>
          <div class="coaching-faq__answer">
            <p>{{ section.settings.faq3_a }}</p>
          </div>
        </div>
        
        <!-- FAQ 4 -->
        <div class="coaching-faq__item">
          <button class="coaching-faq__button" onclick="toggleFaq(this)">
            <span>{{ section.settings.faq4_q }}</span>
            <span class="coaching-faq__icon">▼</span>
          </button>
          <div class="coaching-faq__answer">
            <p>{{ section.settings.faq4_a }}</p>
          </div>
        </div>
        
      </div>
    </div>
  </div>

</section>

<script>
  function toggleFaq(button) {
    var item = button.parentElement;
    var isOpen = item.classList.contains('coaching-faq__item--open');
    
    // Close any other open FAQ items first for standard accordion feel
    var openItems = document.querySelectorAll('.coaching-faq__item--open');
    openItems.forEach(function(el) {
      el.classList.remove('coaching-faq__item--open');
    });
    
    // Toggle current item
    if (!isOpen) {
      item.classList.add('coaching-faq__item--open');
    }
  }
  
  // Smooth scroll helper for anchors
  document.querySelectorAll('.coaching-page-wrapper a[href^="#"]').forEach(function(anchor) {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      var targetId = this.getAttribute('href');
      var targetElement = document.querySelector(targetId);
      if (targetElement) {
        var headerOffset = 80;
        var elementPosition = targetElement.getBoundingClientRect().top;
        var offsetPosition = elementPosition + window.pageYOffset - headerOffset;
        
        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth'
        });
      }
    });
  });
</script>

