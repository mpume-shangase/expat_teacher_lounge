{%- paginate blog.articles by 6 -%}

<!-- Blog Page Hero -->
<section class="relative flex items-center justify-center overflow-hidden" id="blog-hero-{{ section.id }}" style="height: 60vh; min-height: 480px; background-color: #0a0b14; color: #ffffff;">
  
  <style>
    #blog-hero-{{ section.id }} h1 {
      color: #ffffff !important;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5) !important;
    }
    #blog-hero-{{ section.id }} p {
      color: rgba(255, 255, 255, 0.85) !important;
      text-shadow: 0 2px 6px rgba(0, 0, 0, 0.5) !important;
    }
  </style>

  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" 
           alt="The Lounge Blog Hero" 
           style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
           loading="eager">
    {%- else -%}
      <!-- Default fallback background image -->
      <img src="{{ 'Edwina_reading_a_book.png' | asset_url }}" 
           alt="The Lounge Blog Hero Fallback" 
           style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
           loading="eager">
    {%- endif -%}
    
    <!-- Dark gradient overlay to ensure legibility and seamless white bottom transition -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(10, 11, 20, 0.95) 0%, rgba(10, 11, 20, 0.7) 50%, var(--bg-light, #ffffff) 100%); z-index: 1;"></div>
  </div>

  <!-- Hero Content -->
  <div class="container relative z-10" style="margin-top: 80px; text-align: center; width: 100%;">
    <h1 class="font-display font-black" style="font-size: clamp(2.5rem, 6vw, 4.5rem); margin-bottom: 24px; line-height: 1.1; color: #ffffff;">
      {{ section.settings.hero_title_prefix }} <span class="italic" style="color: #FCCB52; font-style: italic;">{{ section.settings.hero_title_gold }}</span>
    </h1>
    <p style="font-size: clamp(1.1rem, 2.5vw, 1.45rem); max-width: 650px; margin-left: auto; margin-right: auto; line-height: 1.5;">
      {{ section.settings.hero_description }}
    </p>
  </div>

</section>

<!-- Blog Listing Page Content -->
<section class="section-padding bg-light text-light" style="padding-top: 80px; padding-bottom: 120px; background-color: var(--bg-light);">
  <div class="container">
    
    <div class="blog-layout-grid" style="display: grid; grid-template-columns: 1fr; gap: 48px;">
      
      <!-- Left Column: Blog list -->
      <div class="blog-articles-list">
        {%- for article in blog.articles -%}
          <article class="blog-horizontal-card group" style="display: flex; flex-direction: column; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: var(--border-radius-lg); overflow: hidden; margin-bottom: 32px; box-shadow: var(--shadow-sm); transition: var(--transition-smooth); width: 100%;">
            
            <a href="{{ article.url }}" style="display: flex; flex-direction: column; width: 100%; height: 100%;">
              <div class="blog-card-inner" style="display: flex; flex-direction: column; padding: 32px; gap: 32px; width: 100%;">
                
                <!-- Inset Article Image -->
                <div class="blog-card-image-wrapper" style="width: 100%; aspect-ratio: 16/10; overflow: hidden; border-radius: var(--border-radius-md); border: 1px solid #e5e7eb; background-color: #f3f4f6; flex-shrink: 0; position: relative;">
                  {%- if article.image != blank -%}
                    <img src="{{ article.image | image_url: width: 800 }}" 
                         alt="{{ article.title | escape }}" 
                         style="width: 100%; height: 100%; object-fit: cover; transition: var(--transition-smooth);"
                         class="blog-card-img"
                         loading="lazy">
                  {%- else -%}
                    <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);"></div>
                  {%- endif -%}
                </div>

                <!-- Article Content -->
                <div class="blog-card-content-wrapper" style="display: flex; flex-direction: column; justify-content: center; flex-grow: 1; width: 100%;">
                  
                  <!-- Tag / Category Badge (Displays first tag) -->
                  {%- if article.tags.size > 0 -%}
                    <span class="blog-tag-badge" style="background-color: rgba(28, 145, 215, 0.08); color: var(--color-blue); padding: 6px 14px; border-radius: var(--border-radius-full); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; align-self: flex-start; margin-bottom: 16px; letter-spacing: 0.05em; font-family: var(--font-body);">
                      {{ article.tags.first }}
                    </span>
                  {%- endif -%}

                  <!-- Title -->
                  <h3 class="font-display font-bold blog-card-title" style="font-size: 1.75rem; line-height: 1.3; color: var(--text-light); margin-top: 0; margin-bottom: 12px; transition: var(--transition-smooth);">
                    {{ article.title }}
                  </h3>

                  <!-- Excerpt -->
                  <p class="blog-card-excerpt" style="color: #64748b; font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; font-family: var(--font-body);">
                    {%- if article.excerpt.size > 0 -%}
                      {{ article.excerpt | strip_html | truncatewords: 24 }}
                    {%- else -%}
                      {{ article.content | strip_html | truncatewords: 24 }}
                    {%- endif -%}
                  </p>

                  <!-- Meta Info (Author & Read Time) -->
                  <div style="font-size: 0.85rem; color: #888899; display: flex; align-items: center; gap: 8px; margin-top: auto; font-family: var(--font-body);">
                    <span>{{ article.author }}</span>
                    <span>&bull;</span>
                    {%- assign word_count = article.content | strip_html | split: ' ' | size -%}
                    {%- assign read_time = word_count | divided_by: 200 | plus: 1 -%}
                    <span>{{ read_time }} min read</span>
                  </div>

                </div>

              </div>
            </a>

          </article>
        {%- else -%}
          <div style="text-align: center; padding: 64px 0; color: #888899;">
            No articles found in this blog.
          </div>
        {%- endfor -%}

        <!-- Pagination -->
        {%- if paginate.pages > 1 -%}
          <div style="display: flex; justify-content: center; gap: 16px; align-items: center; border-top: 1px solid #e5e7eb; padding-top: 32px; font-size: 0.95rem; margin-top: 48px;">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" style="color: var(--color-blue); font-weight: 700;">&larr; Previous</a>
            {%- endif -%}
            
            <span style="color: #64748b;">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" style="color: var(--color-blue); font-weight: 700;">Next &rarr;</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right Column: Sidebar -->
      <aside class="blog-sidebar" style="width: 100%;">
        <div style="background-color: #fafafc; border: 1px solid #e5e7eb; border-radius: var(--border-radius-lg); padding: 32px; position: sticky; top: 120px;">
          
          <h2 class="font-display font-bold" style="font-size: 1.5rem; margin-bottom: 24px; color: var(--text-light); border-bottom: 1px solid #e5e7eb; padding-bottom: 16px;">
            Categories
          </h2>

          <ul style="list-style: none; padding: 0; margin: 0;">
            {%- if blog.all_tags.size > 0 -%}
              {%- for tag in blog.all_tags -%}
                <li style="margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; display: flex; justify-content: space-between; align-items: center;">
                  <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="blog-sidebar-tag-link" style="font-weight: 600; color: #475569; transition: var(--transition-smooth); font-family: var(--font-body); font-size: 0.95rem;">
                    {{ tag | capitalize }}
                  </a>
                  <span class="blog-sidebar-tag-count" style="font-size: 0.75rem; font-weight: 700; background-color: #e2e8f0; color: #475569; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: var(--font-body);">
                    {%- assign tag_count = 0 -%}
                    {%- for article_item in blog.articles -%}
                      {%- if article_item.tags contains tag -%}
                        {%- assign tag_count = tag_count | plus: 1 -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {{ tag_count }}
                  </span>
                </li>
              {%- endfor -%}
            {%- else -%}
              <!-- Static placeholders if blog has no tags -->
              {%- assign placeholder_tags = "Qatar,UAE,Contracts,Recruitment,Interviews" | split: "," -%}
              {%- assign placeholder_counts = "8,1,2,3,2" | split: "," -%}
              {%- for tag in placeholder_tags -%}
                <li style="margin-bottom: 16px; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; display: flex; justify-content: space-between; align-items: center;">
                  <span style="font-weight: 600; color: #888899; font-family: var(--font-body); font-size: 0.95rem;">
                    {{ tag }}
                  </span>
                  <span class="blog-sidebar-tag-count" style="font-size: 0.75rem; font-weight: 700; background-color: #e2e8f0; color: #888899; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-family: var(--font-body);">
                    {{ placeholder_counts[forloop.index0] }}
                  </span>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>

        </div>
      </aside>

    </div>

  </div>
</section>

<!-- Custom Self-contained CSS Styles for the Blog section -->
<style>
  .blog-horizontal-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-blue) !important;
    box-shadow: var(--shadow-md) !important;
  }
  .blog-horizontal-card:hover .blog-card-title {
    color: var(--color-blue) !important;
  }
  .blog-horizontal-card:hover .blog-card-img {
    transform: scale(1.03);
  }
  .blog-sidebar-tag-link:hover {
    color: var(--color-blue) !important;
    padding-left: 4px;
  }
  
  @media (min-width: 768px) {
    .blog-card-inner {
      flex-direction: row !important;
    }
    .blog-card-image-wrapper {
      width: 35% !important;
      height: auto !important;
      aspect-ratio: 4/3 !important;
    }
  }
  
  @media (min-width: 992px) {
    .blog-layout-grid {
      grid-template-columns: 2.3fr 1fr !important;
    }
  }
</style>

{%- endpaginate -%}

{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "hero_title_prefix",
      "label": "Hero Title Prefix",
      "default": "The"
    },
    {
      "type": "text",
      "id": "hero_title_gold",
      "label": "Hero Title Gold",
      "default": "Lounge."
    },
    {
      "type": "textarea",
      "id": "hero_description",
      "label": "Hero Description",
      "default": "Real stories and hard data from the international teaching circuit."
    }
  ]
}
{% endschema %}
