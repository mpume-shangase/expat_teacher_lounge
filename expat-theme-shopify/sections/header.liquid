{%- liquid
  assign main_menu = linklists[section.settings.menu]
-%}

<header class="site-header" role="banner">
  <div class="container flex items-center justify-between">
    
    <!-- Logo or Shop Title -->
    <a href="{{ routes.root_url }}" class="site-header__logo-link flex items-center animate-fade-in">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 360 }}"
             alt="{{ shop.name | escape }}"
             style="max-width: {{ section.settings.logo_max_width }}px; height: auto;"
             class="object-contain"
             loading="lazy">
      {%- else -%}
        <img src="{{ 'expat_teachers_lounge_logo.png' | asset_url }}"
             alt="{{ shop.name | escape }}"
             style="max-width: {{ section.settings.logo_max_width | default: 180 }}px; height: auto;"
             class="object-contain"
             loading="lazy">
      {%- endif -%}
    </a>

    <!-- Desktop Navigation Menu -->
    <nav class="site-header__nav" role="navigation">
      {%- for link in main_menu.links -%}
        <a href="{{ link.url }}" class="site-header__link {% if link.active %}site-header__link--active{% endif %}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <!-- Right Side Actions (Cart & Mobile Toggle) -->
    <div class="site-header__actions">
      <!-- Cart Icon Link -->
      <a href="{{ routes.cart_url }}" class="site-header__cart" aria-label="Cart">
        <svg class="site-header__cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width: 22px; height: 22px; display: block;">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      <!-- Mobile Navigation Trigger -->
      <button type="button" class="mobile-nav-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </div>
</header>

<!-- Mobile Navigation Drawer -->
<div class="mobile-menu-drawer">
  <nav class="flex flex-col gap-4">
    {%- for link in main_menu.links -%}
      <a href="{{ link.url }}" class="mobile-menu-drawer__link">
        {{ link.title }}
      </a>
    {%- endfor -%}
  </nav>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Custom Logo Width",
      "default": 180
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
