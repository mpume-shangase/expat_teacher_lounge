<section class="section-padding bg-light text-light" style="padding-top: 140px;">
  <div class="container" style="max-width: 800px;">
    <h1 class="font-display font-black" style="font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 32px;">{{ page.title }}</h1>
    <div class="rte font-body" style="font-size: 1.1rem; line-height: 1.7; color: #334155;">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
